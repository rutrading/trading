# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading
REDIS_URL=redis://localhost:6379/0

# Auth
AUTH_SERVER_URL=http://localhost:3000
# JWT_AUDIENCE / JWT_ISSUER default to AUTH_SERVER_URL, matching the better-auth
# JWT plugin's defaults (both aud and iss are set to its baseURL). Set these
# only if better-auth is configured with an explicit jwt.audience/jwt.issuer
# that differs from AUTH_SERVER_URL.
#JWT_AUDIENCE=http://localhost:3000
#JWT_ISSUER=http://localhost:3000
# SKIP_AUTH must ONLY be true in local development. The backend refuses to
# start when SKIP_AUTH=true is combined with a non-localhost DATABASE_URL or
# AUTH_SERVER_URL.
SKIP_AUTH=true
LOG_LEVEL=INFO
ALLOW_SYMBOL_SEED_ENDPOINT=false
SYMBOL_SEED_ON_STARTUP=true
SYMBOL_SEED_REFRESH_INTERVAL_SECONDS=86400

# Quotes
QUOTE_STALENESS_SECONDS=60
QUOTE_FLUSH_INTERVAL=30
# Set to rest in local dev to avoid opening upstream/browser WebSockets.
MARKET_DATA_TRANSPORT=ws

# Alpaca
# Optional for local dev. Required for live market data and full symbol seeding.
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_FEED=iex
ALPACA_RATE_LIMIT=200

#alpha vantage
ALPHA_VANTAGE_API_KEY=your_alpha_key_here

# Alpaca WebSocket
ALPACA_WS_STOCKS_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_WS_CRYPTO_URL=wss://stream.data.alpaca.markets/v1beta3/crypto/us
ALPACA_WS_SYMBOL_LIMIT=30

# Kalshi (demo-only in v1)
# KALSHI_PRIVATE_KEY_PEM accepts either real newlines (wrap the value in
# double quotes and paste the PEM as-is across multiple lines) or literal
# \n escapes (single line, also double-quoted). Use whichever the target
# env editor accepts; the loader normalises both. Coolify env panels are
# typically single-line, so prefer the \n-escaped form when pasting there.
KALSHI_API_KEY_ID=your_kalshi_key_id_here
KALSHI_PRIVATE_KEY_PEM=your_kalshi_private_key_here
KALSHI_API_ORIGIN=https://demo-api.kalshi.co
KALSHI_API_PREFIX=/trade-api/v2
KALSHI_BTC_SERIES_TICKER=KXBTCD
KALSHI_RATE_LIMIT=60
KALSHI_POLL_INTERVAL_SECONDS=30
KALSHI_DEFAULT_STRATEGY=threshold_drift
KALSHI_MAX_ORDERS_PER_CYCLE=1
KALSHI_MAX_OPEN_CONTRACTS=5
KALSHI_ORDER_TIME_IN_FORCE=immediate_or_cancel
# Master kill switch. When false the kalshi router is not registered (every
# /api/kalshi/* returns 404), the bot loop is forced off, the dashboard,
# sidebar entry, and account-creation buttons are hidden, and the
# createKalshiAccount server action refuses. Default true so existing deploys
# keep working until the operator opts out.
KALSHI_ENABLED=false
# Bot loop is gated by these (read via env_bool); both default off / on.
KALSHI_BOT_ENABLED=false
KALSHI_DRY_RUN_DEFAULT=true
