{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && shx mkdir -p public && shx cp -r public .next/standalone/web/public && shx cp -r .next/static .next/standalone/web/.next/static",
    "start": "node .next/standalone/web/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate && bun run scripts/idempotent-migrations.ts",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@phosphor-icons/react": "^2.1.10",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-table": "^8",
    "@tanstack/react-virtual": "^3.13.24",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.11.0",
    "motion": "^12.35.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-dropzone": "^15.0.0",
    "react-use-websocket": "^4.13.0",
    "recharts": "2.15.4",
    "resend": "^6.12.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "shadcn": "^3.8.4",
    "shx": "^0.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
