{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && shx mkdir -p public && shx cp -r public .next/standalone/web/public && shx cp -r .next/static .next/standalone/web/.next/static",
    "start": "node .next/standalone/web/server.js",
    "lint": "eslint",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate && bun run scripts/idempotent-migrations.ts",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "lightweight-charts": "^5.1.0",
    "motion": "^12.35.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-use-websocket": "^4.13.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "shx": "^0.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
